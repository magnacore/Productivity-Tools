#!/opt/anaconda3/envs/xonsh/bin/xonsh

from rich.console import Console
console = Console()

console.rule(f"[bold cyan]Backing up queue...")

rsync -vahiP --delete /media/$USER/QUEUE_01_A/QUEUE/ /media/$USER/QUEUE_01_B/QUEUE_BACKUP/

date > ~/.local/state/shortcut/queue-backup.txt

console.rule(style="cyan")

audio-play ~/.local/bin/oxygen-sound-theme/Oxygen-K3B-Finish-Success.ogg &
