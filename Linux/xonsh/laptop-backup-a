#!/opt/anaconda3/envs/xonsh/bin/xonsh

from rich.console import Console

console = Console()

console.rule(f"[bold cyan]Laptop Backup A...", style="cyan")

# Remove the old log file so we start fresh
rm -f $HOME/.local/state/shortcut/copy_log.txt

#rsync -vahiP --delete --exclude-from=$HOME/Backups/RSYNC_EXCLUDE/rsync-homedir-local.txt $HOME/ /media/veracrypt1/SYSTEM_BACKUP/
sudo rsync -vahi --partial --info=progress2 --delete --log-file=$HOME/.local/state/shortcut/copy_log.txt --exclude-from=$HOME/Backups/RSYNC_EXCLUDE/rsync-homedir-local.txt $HOME/ /media/veracrypt1/SYSTEM_BACKUP/

date > ~/.local/state/shortcut/laptop-backup-a.txt
date > /media/veracrypt1/SYSTEM_BACKUP/backup_date.txt

console.rule(style="cyan")

audio-play ~/.local/bin/oxygen-sound-theme/Oxygen-K3B-Finish-Success.ogg &
